# Talise web — environment template
# Copy to .env.local and fill in real values. Never commit .env.local.
#
# When deploying to Railway, set every value below in the project's
# Variables panel (NOT just NEXT_PUBLIC_* — server-only secrets too).

# ── App ──────────────────────────────────────────────────────────────
# Public origin where this app is reachable. Used for OAuth state +
# absolute URLs in emails. Must match the Google redirect URI host.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Cloudflare Turnstile (bot protection) ────────────────────────────
# Cloudflare Turnstile — bot protection on the public email-signup
# endpoint (/api/waitlist). Get keys at https://dash.cloudflare.com →
# Turnstile. Without the secret, /api/waitlist falls back to
# rate-limit-only (logs a warning) — set this before exposing the
# endpoint publicly. See audit F9.
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ── Google OAuth (zkLogin sign-in) ───────────────────────────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials
# Application type: Web application
# Authorized redirect URI:
#   http://localhost:3000/auth/callback (dev)
#   https://<your-domain>/auth/callback (prod)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# Separate iOS OAuth client (Application type: iOS, Bundle ID: io.talise.app).
# iOS clients don't get a client secret — PKCE handles that. The iOS app
# embeds this in Info.plist > TaliseGoogleClientID; the backend uses it
# to validate the `aud` claim on id_tokens received at /api/auth/mobile/exchange.
# A fresh client at https://console.cloud.google.com → Credentials → Create
GOOGLE_CLIENT_ID_IOS=

# ── Sui network ──────────────────────────────────────────────────────
# "mainnet" requires SHINAMI_API_KEY below.
# "testnet" uses Mysten's open testnet prover — fine for dev.
NEXT_PUBLIC_SUI_NETWORK=mainnet

# ── Shinami zkLogin (mainnet prover + salt service) ──────────────────
# Get a key at https://app.shinami.com. Replaces Mysten's audience-gated
# mainnet prover. Docs: https://docs.shinami.com/api-docs/sui/wallet-services/zklogin-wallet-api
SHINAMI_API_KEY=

# ── Shinami Node Service (mainnet JSON-RPC fullnode) ─────────────────
# Optional. When set, the gasless send's prepare-build AND iOS direct-
# broadcast path route through Shinami's paid mainnet node instead of
# `fullnode.mainnet.sui.io`. Unset → both fall back to public.
#
# This is a DIFFERENT key from SHINAMI_API_KEY above — the Node Service
# is a separate Shinami product. Provision it in the same dashboard.
SHINAMI_NODE_API_KEY=

# ── Gas sponsorship (Onara) ──────────────────────────────────────────
# Run locally: cd onara/api && bun run dev → http://localhost:8787
# Or deploy to Cloudflare Workers and point this at the prod URL.
ONARA_URL=http://localhost:8787

# When true (default), every signAndSubmit goes through Onara so the user
# never needs SUI for gas. Set false to fall back to sender-pays-gas.
NEXT_PUBLIC_SPONSOR_ENABLED=true

# ── Database ─────────────────────────────────────────────────────────
# Local dev: file:./.data/talise.db  (auto-created on first query)
# Production:
#   - Turso: libsql://<your-db>.turso.io + DATABASE_AUTH_TOKEN
#   - Railway with the libSQL service: pulled from the service env
DATABASE_URL=file:./.data/talise.db
DATABASE_AUTH_TOKEN=

# ── Session signing ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# Used to HMAC-sign the session, jwt, state, and referral cookies.
SESSION_SECRET=

# ── SuiNS operator (mints `<name>.talise.sui` subnames) ──────────────
# Bech32-encoded Ed25519 secret key (`suiprivkey1...`) of the wallet
# that owns the `talise.sui` parent name NFT. This wallet also doubles
# as the Payment Kit operator unless TALISE_PK_OPERATOR_KEY is set
# explicitly. Pays its own gas — keep ~0.1 SUI on it for headroom.
TALISE_SUINS_OPERATOR_KEY=

# The on-chain object id of the `talise.sui` parent NFT, plus its
# expiry timestamp in ms. Both are required for subname mints.
TALISE_SUI_NFT_ID=
TALISE_SUI_EXPIRY_MS=

# ── Payment Kit operator (optional override) ─────────────────────────
# If set, this key mints + holds the AdminCap for the global `talise`
# PaymentRegistry. Otherwise we fall back to TALISE_SUINS_OPERATOR_KEY.
# The registry is lazily minted by /api/zk/warmup the first time any
# user loads the dashboard.
TALISE_PK_OPERATOR_KEY=

# Force-disable Payment Kit receipts (kill switch).
# Default: enabled — receipts attach automatically once the warmup
# endpoint confirms the registry exists on chain.
# NEXT_PUBLIC_PK_RECEIPTS_ENABLED=false

# ── Resend (transactional email, optional) ───────────────────────────
# Without this, email-on-receive + invoice-paid notifications no-op.
RESEND_API_KEY=
EMAIL_FROM=Talise <onboarding@resend.dev>
EMAIL_REPLY_TO=hello@talise.io

# ── Waitlist confirmation email (Resend) ─────────────────────────────
# Sent automatically after a successful POST to /api/waitlist. The
# `from` address must live on a Resend-verified domain (talise.io). If
# RESEND_API_KEY is unset, the waitlist still records the signup but
# the confirmation email is skipped (logged as a warning).
WAITLIST_FROM_EMAIL=Talise <waitlist@talise.io>
# Optional BCC for ops monitoring. Leave blank to disable.
WAITLIST_BCC_EMAIL=
# Public origin used to build the image URL inside the email body.
# Defaults to NEXT_PUBLIC_BASE_URL when unset.
NEXT_PUBLIC_APP_URL=https://talise.io

# ── Admin token (gates internal-only routes) ─────────────────────────
# Any 32+ char random string. Required by `/api/admin/*` endpoints.
ADMIN_TOKEN=

# ── Agentic chat (DeepSeek V4 Pro via 0G Compute) ────────────────────
# OpenAI-compatible proxy. The agent on /home calls this for every
# message. Without it, the chat panel renders but tells the user
# "the chat is offline" — sends + dashboard still work.
ZG_DEEPSEEK_V4_PROVIDER_URL=https://compute-network-21.integratenetwork.work/v1/proxy
ZG_DEEPSEEK_V4_API_KEY=

# Optional: Memwal persistent agent memory (Walrus + Sui). Without it
# the chat is per-session — refreshing the page starts a new conversation.
# Provision via the deeplens repo's scripts/memwal-setup.mjs.
MEMWAL_ACCOUNT_ID=
MEMWAL_DELEGATE_KEY=
MEMWAL_SERVER_URL=https://relayer.memwal.ai

# ── Stripe Crypto Onramp ─────────────────────────────────────────────
# Server-only secret. Get a key at https://dashboard.stripe.com/apikeys
# (use the test-mode `sk_test_…` key for development; `sk_live_…` for prod).
#
# Crypto Onramp also requires enabling crypto in the Stripe dashboard:
#   Dashboard → Crypto → Get started → enable for your account.
#
# Note: Stripe Crypto Onramp delivers USDC on Sui mainnet (not USDsui directly).
# The AutoConvertBanner on /home sweeps inbound USDC → USDsui in one tap, so
# the user's net effect is "buy USDsui with a card".
STRIPE_SECRET_KEY=

# Public publishable key — REQUIRED for the embedded Onramp SDK
# (@stripe/crypto). Without this, the "Top up with card" modal can't load
# Stripe's iframe and will surface an error. Get it from the same dashboard
# page as STRIPE_SECRET_KEY (use `pk_test_…` in dev, `pk_live_…` in prod).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Optional — webhook signing secret for `/api/onramp/webhook`. Get one by
# creating a webhook endpoint at https://dashboard.stripe.com/webhooks and
# subscribing to `crypto.onramp_session.updated`. The embedded SDK already
# gives us the success signal client-side, so this is purely for backend
# durability/audit.
STRIPE_WEBHOOK_SECRET=

# ── Provider-agnostic on-ramp + KYC (scaffold, dormant) ──────────────
# Additive "Add money" scaffold under /api/onramp/v2/* + AddMoneyModal.
# Dormant until NEXT_PUBLIC_ONRAMP_ENABLED=true; ships ALONGSIDE the
# Stripe routes above without replacing them. See web/lib/onramp/README.md.
#
# Feature flag — gates the modal + /v2 routes. Leave unset/false to keep
# the whole scaffold inert. Public (NEXT_PUBLIC_) so the client can read it.
NEXT_PUBLIC_ONRAMP_ENABLED=false
# Which adapter to use: `bridge` (delivers USDsui DIRECTLY on Sui via virtual
# accounts — no swap; also powers Bridge OFF-RAMP via liquidation addresses) or
# `transak` (hosted widget does KYC, delivers USDC on Sui, then a swap-to-USDsui
# step). Bridge serves USD/EUR/GBP corridors; NGN is NOT a Bridge rail (Nigerian
# payout stays on Linq).
ONRAMP_PROVIDER=bridge
# Bridge (https://apidocs.bridge.xyz). With BRIDGE_API_KEY unset, the on-ramp
# adapter runs as a STUB and the off-ramp routes return 503 — no network, no
# money. Shared across on-ramp (lib/bridge/onramp.ts) + off-ramp
# (lib/bridge/offramp.ts).
#   BRIDGE_API_KEY        dashboard-issued; sent as the `Api-Key` header
#   BRIDGE_API_BASE       optional base URL override (default
#                         https://api.bridge.xyz/v0 ; set for sandbox)
#   BRIDGE_WEBHOOK_PUBKEY PEM RSA PUBLIC key for the webhook endpoint, returned
#                         by registerWebhook(). Bridge signs X-Webhook-Signature:
#                         t=<ms>,v0=<base64>; the verifier tries the official
#                         double-hash then single-hash. `\n` newlines OK. Unset
#                         → webhooks are marked unverified.
#   BRIDGE_DEVELOPER_FEE_PERCENT  Talise's platform fee, string % (default "1.0").
# Sui uses payment_rail "sui" + currency "usdc" (USDC on Sui). Sandbox base:
# https://api.sandbox.bridge.xyz/v0 with an sk-test key.
BRIDGE_DEVELOPER_FEE_PERCENT=1.0
BRIDGE_API_KEY=
BRIDGE_API_BASE=
BRIDGE_WEBHOOK_PUBKEY=
# Transak (LIVE provider). Create a partner account at https://transak.com
# (dashboard → API keys). With TRANSAK_API_KEY unset, createOnrampSession
# returns a harmless stub URL so the flow can be exercised without an account.
#   TRANSAK_API_KEY       partner API key
#   TRANSAK_API_SECRET    webhook JWT (HS256) signing secret — verifies
#                         /api/onramp/v2/kyc-webhook posts
#   TRANSAK_ENVIRONMENT   PRODUCTION | STAGING (default STAGING)
# The widget delivers USDC on the Sui network to the signed-in user's address;
# the USDC→USDsui swap (/api/swap/prepare) finishes money-in.
TRANSAK_API_KEY=
TRANSAK_API_SECRET=
TRANSAK_ENVIRONMENT=STAGING

# ── Linq off-ramp (USDSUI → NGN bank payout) ─────────────────────────
# The Nigerian off-ramp provider (replaces Paga). Linq hands back a deposit
# wallet it watches and pays the bank itself — no treasury float needed.
# Onboard ONCE with your 7-char invite code (returns the keys, shown once):
#   curl -X POST $LINQ_BASE_URL/b2b/signup -H 'Content-Type: application/json' \
#     -d '{"registrationCode":"XXXXXXX","businessName":"Talise","email":"...",
#          "password":"...","webhookUrl":"https://www.talise.io/api/offramp/linq/webhook"}'
#   LINQ_API_KEY         biz_live_…  (X-API-Key on all calls)
#   LINQ_WEBHOOK_SECRET  whsec_…     (verifies X-Linq-Signature on the webhook)
#   LINQ_BASE_URL        optional host override (default is the prod host)
# With LINQ_API_KEY unset, the /api/offramp/linq/* routes return 503.
LINQ_API_KEY=
LINQ_WEBHOOK_SECRET=
LINQ_BASE_URL=

# ── Upstash Redis (global rate limiting) ─────────────────────────────
# Upstash Redis — global rate limiting across serverless instances.
# Without these, rate limiting falls back to per-instance in-memory
# (fine for dev; NOT safe at scale — see audit F3).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Cheques (claimable USDsui links) ─────────────────────────────────
# Claimable money links presented as real-life cheques (web/lib/cheques.ts).
# TWO interchangeable rails, picked at RUNTIME by which vars are set:
#
#   • ESCROW rail (the live fallback): set ONLY CHEQUE_ESCROW_SK. Funds are
#     held in a single Talise-controlled escrow address; the claim API + the
#     expiry-sweep cron release them with escrow→recipient transfers signed by
#     this key. With CHEQUE_ESCROW_SK unset, the whole cheques feature is OFF
#     (chequesEnabled() === false) and the create/claim routes no-op.
#
#   • ON-CHAIN rail (additive, recommended): set ALL THREE of CHEQUE_ESCROW_SK
#     + CHEQUE_PACKAGE_ID + CHEQUE_REGISTRY_ID. Funds live in a per-cheque
#     on-chain `Cheque<USDSUI>` object; the key here acts as the registered
#     `cheque::claim` worker (pays its own SUI gas — keep ~0.1 SUI on it).
#     A half-configured env (e.g. package id but no registry) safely degrades
#     to the escrow rail.
#
# NOTE: the on-chain rail REQUIRES the `talise::cheque` Move package to be
# PUBLISHED first — CHEQUE_PACKAGE_ID / CHEQUE_REGISTRY_ID are the published
# package id + the shared ChequeRegistry object id from that publish. Expired
# on-chain cheques are creator-reclaimable only (the worker cannot auto-sweep
# them — cheque::reclaim is creator-signed with no expiry gate).
#
# Bech32-encoded Ed25519 secret key (`suiprivkey1...`). Same key pattern as
# TALISE_SUINS_OPERATOR_KEY.
CHEQUE_ESCROW_SK=
# Published `talise::cheque` package id (enables the on-chain rail).
CHEQUE_PACKAGE_ID=
# Shared `ChequeRegistry` object id from the same publish (on-chain rail).
CHEQUE_REGISTRY_ID=

# ── Streaming payments ───────────────────────────────────────────────
# Streamed USDsui payouts released tranche-by-tranche by the
# /api/cron/process-streams cron (web/lib/streams.ts). TWO rails, same shape
# as cheques:
#
#   • ESCROW rail (live fallback): set ONLY STREAM_ESCROW_SK. The sender funds
#     the FULL amount once into a Talise-controlled escrow address; the cron
#     releases each due tranche with an escrow→recipient transfer signed by
#     this key. With STREAM_ESCROW_SK unset, streaming is OFF
#     (streamEscrowEnabled() === false) and the cron no-ops (200 disabled:true).
#
#   • ON-CHAIN rail (additive): set ALL THREE of STREAM_ESCROW_SK +
#     STREAM_PACKAGE_ID + STREAM_REGISTRY_ID. Funds live in a real shared
#     `Stream<USDSUI>` object; the key here is the registered `stream::release`
#     worker (pays its own SUI gas). A half-configured env degrades to escrow.
#
# NOTE: the on-chain rail REQUIRES the `talise::stream` Move package to be
# PUBLISHED first — STREAM_PACKAGE_ID / STREAM_REGISTRY_ID are the published
# package id + shared StreamRegistry object id.
#
# Bech32-encoded Ed25519 secret key (`suiprivkey1...`).
STREAM_ESCROW_SK=
# Published `talise::stream` package id (enables the on-chain rail).
STREAM_PACKAGE_ID=
# Shared `StreamRegistry` object id from the same publish (on-chain rail).
STREAM_REGISTRY_ID=

# ── Cron auth (protects the money-moving stream scheduler) ───────────
# Shared bearer secret the stream cron checks: Vercel sends
# `Authorization: Bearer ${CRON_SECRET}` on its scheduled GET to
# /api/cron/process-streams. MUST be a strong, non-empty random value
# (e.g. `openssl rand -hex 32`) in production — if it is EMPTY/UNSET the
# gate is skipped and ANYONE can trigger the tranche-release loop with a
# plain GET. Set it before enabling streaming in prod.
CRON_SECRET=

# ── Cheque/stream public links + claim captcha ───────────────────────
# Public origin used to build cheque claim links (https://.../c/<id>#<secret>)
# in web/lib/cheques.ts:chequeBaseUrl(). Defaults to https://www.talise.io
# when unset; set it to this deployment's canonical origin.
TALISE_PUBLIC_URL=https://www.talise.io
#
# Cheque WEB claims reuse the Cloudflare Turnstile keys configured in the
# "Cloudflare Turnstile" block above (TURNSTILE_SECRET_KEY +
# NEXT_PUBLIC_TURNSTILE_SITE_KEY) as the anti-bot captcha gate at claim time.
# When Turnstile is unconfigured the captcha gate is skipped (native app
# claims are App-Attested and skip it regardless). No separate keys needed.

# ── SAM yield vault (usesam.xyz) — aggregating Sui yield venue ────────────
# Routes idle USDC into SAM's share vault (Scallop/Suilend/NAVI + compounded
# rewards). DORMANT until these are set (the adapter no-ops/throws otherwise),
# because SAM's docs don't publish its on-chain interface — fill from SAM or a
# decoded mainnet deposit tx. See docs/strategy/YIELD-ENGINE-SAM.md.
SAM_PACKAGE_ID=
SAM_USDC_VAULT_ID=
SAM_USDC_SHARE_TYPE=
SAM_USDC_COIN_TYPE=
# Optional overrides (defaults shown): SAM_MODULE=vault SAM_DEPOSIT_FN=deposit
# SAM_REDEEM_FN=redeem SAM_VAULT_VALUE_FIELD=total_value
# SAM_VAULT_SHARES_FIELD=total_shares SAM_VAULT_APY_FIELD=

# ── Talise Yield Router (talise_yield::yield_router, Sui mainnet) ─────────
# Published 2026-06-16. Non-custodial rotating yield across the 4 USDsui
# venues. Defaults are hardcoded in web/lib/yield/onchain.ts; override here
# only after an UpgradeCap upgrade or a redeploy.
TALISE_YIELD_PACKAGE_ID=0xa58f2dee1dd01ac655ef2d9180a96228ab4667219049cfc1286752b3923ad730
TALISE_YIELD_REGISTRY_ID=0x9ba71e5164254040f60a439abb7317670a90437b3603a22ca3eceac92c3d7e21

# ── Talise Privacy / shielded pool (talise_privacy::shielded_pool) ───────
# Workstream C end-to-end is WIRED (web/lib/shield/sdk/flow.ts ties keys →
# merkle-path → WASM Groth16 prove → P-256 ECIES → transact PTB → relay) and
# Poseidon parity is VERIFIED (browser proofs verify on-chain).
# shieldConfigured() (lib/shield/onchain.ts) gates every /api/shield/* route,
# the indexer cron, and the merkle-path service on SHIELD_PKG + SHIELD_POOL_USDSUI.
#
# MAINNET capped pilot — published 2026-06-17, $10/tx caps. The VK is a
# SINGLE-PARTY OsRng setup (operator-trusted, NOT outsider-forgeable; trustless
# scale still needs the multi-party ceremony + audit — constants.move). Kept
# COMMENTED so prod stays gated until the relayer keypair is funded + set;
# uncomment SHIELD_PKG/REGISTRY/POOL + the relayer vars TOGETHER to flip on, and
# leave SUI_FULLNODE_URL on mainnet (the default).
# SHIELD_PKG=0x8722790773958722225cf91f5a6762689dc13f97076534c05ebd3505d586f9bf
# SHIELD_REGISTRY_ID=0x546fd6c97508869cf3c25a641abc8d241c8010b60ba0b1b72b7ebe3d2a12ccab
# SHIELD_POOL_USDSUI=0x6bcd28763456db543d0c29acb34970b81e4d7f004d2581fce46b813ece8152c1
# SHIELD_FIRST_CHECKPOINT=287822580   # publish checkpoint — indexer starts here
# SHIELD_RELAYER_ADDRESS=             # `sui keytool generate ed25519`. NO funding needed — Onara owns/pays gas.
# SHIELD_RELAYER_SK=                  # relayer privkey (suiprivkey1… bech32). Signs only; NEVER a witness-holder. Set "sensitive".
# SHIELD_MAX_RELAYER_FEE=0            # pilot relays are fee-free
# CRON_SECRET=                        # random hex; gates /api/cron/shield-indexer (Vercel auto-injects it on cron runs)
# Admin caps held by the deploy wallet (mainnet_funded_20260615):
#   PoolAdminCap (pause / re-cap): 0xaba382239cdd835d586dc6b16aadef0469ed296e12e478539a6db35eb6569384
#   UpgradeCap:                    0xed003bda9a0e076bafdca34fc58bbef39aa2c95069c2cd21fb6b97d567062598

# ── At-rest column encryption (lib/crypto-at-rest.ts) ───────────────────────
# OPT-IN: when set, encrypts sensitive columns at rest (users.salt, apple_salts,
# mobile_sessions jwt+salt, user_bank_accounts.account_number) with AES-256-GCM.
# Unset = passthrough (plaintext, current behaviour). 32 bytes, base64 or hex.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Set the SAME value in .env.local AND Vercel; rotating it orphans existing ciphertext.
DB_ENCRYPTION_KEY=

# On-chain goal vaults (talise_goals package, mainnet). Set to light up
# /api/goals/vault/prepare; unset = goals stay DB tracking-envelopes.
GOAL_VAULT_PACKAGE_ID=0xb0898eef5734ee9ebfbdbacd9e39533d7070159d4a87287ddde8a5b331059947
